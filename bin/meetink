#!/bin/zsh
# meetink — local-first meeting transcription for macOS
# https://github.com/sservaes/meetink

set -e

# --- Locate self ---
SCRIPT_PATH="${0:A}"
MK_BIN_DIR="${SCRIPT_PATH:h}"
MK_ROOT="${MK_BIN_DIR:h}"

# --- Config ---
MEETINK_VERSION="0.1.0"
MK_HOME="${MEETINK_HOME:-$HOME/.meetink}"
MK_MODEL="${MEETINK_MODEL:-}"   # resolved after models.sh is sourced
# Transcripts live in a visible folder by default. Override the directory via
# MEETINK_TRANSCRIPTS_DIR, or pin the live-symlink path with the older
# MEETINK_TRANSCRIPT (expects a full file path).
MK_TRANSCRIPTS_DIR="${MEETINK_TRANSCRIPTS_DIR:-$HOME/Documents/meetink}"
# Base path for project enumeration (subdirs of this are projects). Stays
# fixed even after project_resolve_dirs adjusts $MK_TRANSCRIPTS_DIR to point
# inside an active project's folder.
MK_TRANSCRIPTS_BASE="$MK_TRANSCRIPTS_DIR"
MK_TRANSCRIPT="${MEETINK_TRANSCRIPT:-$MK_TRANSCRIPTS_DIR/live.txt}"
MK_PROMPT="${MEETINK_PROMPT:-$MK_HOME/prompts/default.txt}"
MK_PORT=8178

PID_FILE="/tmp/meetink-capture.pid"
SERVER_PID_FILE="/tmp/meetink-whisper.pid"

# Python venv used for the prompt_toolkit REPL (and shared with diarize-server
# when that's installed — avoids two venvs for the same tools).
MK_PY_VENV="$MK_HOME/py-venv"

# --- UI helpers ---
source "$MK_ROOT/src/lib/ui.sh"
source "$MK_ROOT/src/lib/welcome.sh"
source "$MK_ROOT/src/lib/window.sh"
source "$MK_ROOT/src/lib/models.sh"
source "$MK_ROOT/src/lib/titling.sh"
source "$MK_ROOT/src/lib/diarize.sh"
source "$MK_ROOT/src/lib/projects.sh"
source "$MK_ROOT/src/lib/identity.sh"
source "$MK_ROOT/src/lib/ask.sh"
source "$MK_ROOT/src/lib/summary.sh"
source "$MK_ROOT/src/lib/context.sh"
source "$MK_ROOT/src/lib/index.sh"
source "$MK_ROOT/src/lib/watch.sh"
source "$MK_ROOT/src/lib/repl.sh"

# If an active project is configured, redirect $MK_TRANSCRIPTS_DIR /
# $MK_TRANSCRIPT into its folder before any subcommand runs.
project_resolve_dirs

# Resolve the active model AFTER models.sh is sourced, so the user's
# config-file selection takes effect. Explicit MEETINK_MODEL still wins.
if [[ -z "$MK_MODEL" ]]; then
    MK_MODEL=$(model_path "$(model_active)")
fi

# --- Locate the Swift binary (preferred location: $MK_HOME/bin) ---
find_capture_binary() {
    local candidates=(
        "$MK_HOME/bin/meetink-capture"
        "$MK_ROOT/src/capture/meetink-capture"
        "$MK_ROOT/.build/release/meetink-capture"
    )
    for c in $candidates; do
        if [[ -x "$c" ]]; then
            echo "$c"
            return 0
        fi
    done
    return 1
}

# --- Locate a usable macOS SDK (prefers 15.x to avoid SDK/toolchain mismatches) ---
find_sdk() {
    local sdk_root="/Library/Developer/CommandLineTools/SDKs"
    # Prefer 15.x SDKs (most stable with current Swift CLI)
    for v in 15.5 15.4 15 14.5 14; do
        if [[ -d "$sdk_root/MacOSX${v}.sdk" ]]; then
            echo "$sdk_root/MacOSX${v}.sdk"
            return 0
        fi
    done
    # Fall back to default
    if [[ -d "$sdk_root/MacOSX.sdk" ]]; then
        echo "$sdk_root/MacOSX.sdk"
        return 0
    fi
    return 1
}

# --- Build Swift binary ---
build_capture() {
    print -P "${C[bright_yellow]}▸${C[reset]} Building capture binary..."
    cd "$MK_ROOT/src/capture"
    if ! command -v swiftc >/dev/null 2>&1; then
        print -P "${C[red]}error:${C[reset]} ${C[bold]}swiftc${C[reset]} not found"
        print -P "  Install Xcode Command Line Tools:"
        print -P "  ${C[bright_cyan]}xcode-select --install${C[reset]}"
        exit 1
    fi

    local sdk
    if ! sdk=$(find_sdk); then
        print -P "${C[red]}error:${C[reset]} no macOS SDK found in /Library/Developer/CommandLineTools/SDKs/"
        print -P "  Reinstall command-line tools: ${C[bright_cyan]}xcode-select --install${C[reset]}"
        exit 1
    fi
    print -P "  ${C[dim]}using SDK: ${sdk}${C[reset]}"

    swiftc -O -o meetink-capture Sources/main.swift \
        -framework ScreenCaptureKit -framework AVFoundation \
        -framework CoreMedia -framework CoreAudio \
        -parse-as-library \
        -sdk "$sdk" \
        -target arm64-apple-macosx14.0 || {
            print -P "${C[red]}error:${C[reset]} build failed"
            exit 1
        }
    mkdir -p "$MK_HOME/bin"
    cp meetink-capture "$MK_HOME/bin/meetink-capture"
    print -P "${C[green]}✓${C[reset]} Built: ${C[dim]}$MK_HOME/bin/meetink-capture${C[reset]}"
    cd - > /dev/null
}

# --- Build the macOS-native agent ---
# meetink-agent is a tiny Swift app-bundle that owns the integrations
# Python can't easily reach: EventKit (calendar reading) and
# UserNotifications (action-button notifications). It lives at
# $MK_HOME/bin/MeetinkAgent.app and is invoked one-shot with subcommand
# arguments. Bundling is required so the app gets a CFBundleIdentifier
# (com.meetink.agent) — without it, UserNotifications refuses to deliver
# and EventKit can't request Full Calendar Access.
build_agent() {
    print -P "${C[bright_yellow]}▸${C[reset]} Building meetink-agent (calendar + notifications)..."
    if ! command -v swiftc >/dev/null 2>&1; then
        print -P "${C[red]}error:${C[reset]} ${C[bold]}swiftc${C[reset]} not found"
        print -P "  Install Xcode Command Line Tools:"
        print -P "  ${C[bright_cyan]}xcode-select --install${C[reset]}"
        exit 1
    fi

    local sdk
    if ! sdk=$(find_sdk); then
        print -P "${C[red]}error:${C[reset]} no macOS SDK found"
        exit 1
    fi

    local app="$MK_HOME/bin/MeetinkAgent.app"
    local macos_dir="$app/Contents/MacOS"
    local resources_dir="$app/Contents/Resources"
    mkdir -p "$macos_dir" "$resources_dir"

    swiftc -O -o "$macos_dir/meetink-agent" "$MK_ROOT/src/agent/Sources/main.swift" \
        -framework Foundation -framework EventKit \
        -framework UserNotifications -framework AppKit \
        -framework AVFoundation \
        -sdk "$sdk" \
        -target arm64-apple-macosx14.0 || {
            print -P "${C[red]}error:${C[reset]} agent build failed"
            exit 1
        }

    # Drop the Info.plist into Contents/ — UserNotifications won't fire
    # without CFBundleIdentifier; EventKit's Full Calendar Access prompt
    # uses the NSCalendarsFullAccessUsageDescription string.
    cp "$MK_ROOT/src/agent/Resources/Info.plist" "$app/Contents/Info.plist"

    # Ad-hoc sign so macOS gives the bundle a stable identity for TCC
    # (the permission database) — without this, every rebuild looks
    # like a different app and the user re-grants Calendar / Notification
    # permission each time.
    if command -v codesign >/dev/null 2>&1; then
        codesign --force --sign - "$app" 2>/dev/null || true
    fi

    print -P "${C[green]}✓${C[reset]} Built: ${C[dim]}$app${C[reset]}"
}

# --- Download whisper model ---
download_model() {
    local model_name="${1:-small.en}"
    local target="$MK_HOME/models/ggml-${model_name}.bin"
    local url="https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-${model_name}.bin"

    if [[ -f "$target" ]]; then
        print -P "${C[green]}✓${C[reset]} Model already present: ${C[dim]}$target${C[reset]}"
        return 0
    fi

    print -P "${C[bright_yellow]}▸${C[reset]} Downloading whisper model (${model_name}, ~500 MB)..."
    mkdir -p "$MK_HOME/models"
    if ! curl -L --fail --progress-bar -o "$target" "$url"; then
        print -P "${C[red]}error:${C[reset]} download failed"
        rm -f "$target"
        exit 1
    fi
    print -P "${C[green]}✓${C[reset]} Model downloaded: ${C[dim]}$target${C[reset]}"
}

# --- Install whisper.cpp via brew ---
install_whisper() {
    if command -v whisper-server >/dev/null 2>&1; then
        print -P "${C[green]}✓${C[reset]} whisper-cpp already installed"
        return 0
    fi
    print -P "${C[bright_yellow]}▸${C[reset]} Installing whisper.cpp..."
    if ! command -v brew >/dev/null 2>&1; then
        print -P "${C[red]}error:${C[reset]} Homebrew not found"
        print -P "  Install from ${C[bright_cyan]}https://brew.sh${C[reset]}"
        exit 1
    fi
    brew install whisper-cpp
    print -P "${C[green]}✓${C[reset]} whisper-cpp installed"
}

# --- Python REPL bootstrap ---
# The interactive REPL is implemented in Python (prompt_toolkit) so the
# bottom-pinned status bar renders reliably across resizes and terminal
# emulators. zsh handles only the CLI / setup paths.

repl_install_pytools() {
    # Ensure uv exists (lightning-fast Python package manager).
    if ! command -v uv >/dev/null 2>&1; then
        if ! command -v brew >/dev/null 2>&1; then
            return 1
        fi
        print -P "${C[bright_yellow]}▸${C[reset]} Installing uv..."
        brew install uv >/dev/null 2>&1 || return 1
    fi
    # Create the venv if missing
    if [[ ! -x "$MK_PY_VENV/bin/python" ]]; then
        print -P "${C[bright_yellow]}▸${C[reset]} Creating Python venv for the REPL..."
        if ! uv venv "$MK_PY_VENV" --python 3.11 >/dev/null 2>&1 \
           && ! uv venv "$MK_PY_VENV" >/dev/null 2>&1; then
            return 1
        fi
    fi
    # Ensure prompt_toolkit is installed
    if ! "$MK_PY_VENV/bin/python" -c 'import prompt_toolkit' 2>/dev/null; then
        print -P "${C[bright_yellow]}▸${C[reset]} Installing prompt_toolkit..."
        uv pip install --python "$MK_PY_VENV/bin/python" --quiet prompt_toolkit \
            >/dev/null 2>&1 || return 1
    fi
    return 0
}

# Launch the Python REPL. Falls back to the zsh REPL if Python tooling
# isn't available and can't be installed.
launch_python_repl() {
    if ! repl_install_pytools; then
        print -P "${C[yellow]}⚠${C[reset]} Couldn't set up the Python REPL — falling back to the zsh REPL."
        repl_loop
        return
    fi
    MK_LAUNCHER="$SCRIPT_PATH" \
        "$MK_PY_VENV/bin/python" "$MK_ROOT/src/repl/repl.py"
}

# --- Migrate legacy local-speech install ---
# The project was renamed from local-speech → meetink. If the user installed
# the old version, move ~/.local-speech → ~/.meetink (and the transcripts
# folder), and rename the inner capture binary. One-time, idempotent.
migrate_legacy_install() {
    local old_home="$HOME/.local-speech"
    local old_tx="$HOME/Documents/local-speech"
    local migrated=0

    if [[ -d "$old_home" ]] && [[ ! -d "$MK_HOME" ]]; then
        if mv "$old_home" "$MK_HOME" 2>/dev/null; then
            # Rename the renamed binary inside (was local-speech-capture).
            if [[ -f "$MK_HOME/bin/local-speech-capture" ]]; then
                mv "$MK_HOME/bin/local-speech-capture" "$MK_HOME/bin/meetink-capture"
            fi
            migrated=1
        fi
    fi

    if [[ -d "$old_tx" ]] && [[ ! -d "$MK_TRANSCRIPTS_DIR" ]]; then
        if mv "$old_tx" "$MK_TRANSCRIPTS_DIR" 2>/dev/null; then
            # The old live.txt symlink pointed at an absolute path inside
            # ~/Documents/local-speech/, which no longer exists. Drop the
            # broken symlink — /start will recreate one for the next session.
            local live="$MK_TRANSCRIPTS_DIR/live.txt"
            [[ -L "$live" && ! -e "$live" ]] && rm -f "$live"
            migrated=1
        fi
    fi

    if (( migrated )); then
        print -P "${C[dim]}Migrated local-speech → meetink (data, binary, transcripts)${C[reset]}"
    fi
}

# --- Migrate legacy transcripts ---
# One-time move: old default was $MK_HOME/transcripts/ (hidden); new default
# is $MK_TRANSCRIPTS_DIR (visible, defaults to ~/Documents/meetink/).
# Renames the singleton "live.txt" using its mtime so it isn't overwritten
# the next time we set up a fresh symlink.
migrate_transcripts() {
    local old_dir="$MK_HOME/transcripts"
    [[ -d "$old_dir" ]] || return 0

    mkdir -p "$MK_TRANSCRIPTS_DIR"
    local moved=0

    setopt local_options null_glob
    for f in "$old_dir"/*; do
        [[ -f "$f" ]] || continue
        local basename="${f:t}"
        local target
        if [[ "$basename" == "live.txt" ]]; then
            local mtime=$(stat -f "%Sm" -t "%Y-%m-%d_%H-%M-%S" "$f" 2>/dev/null)
            [[ -z "$mtime" ]] && mtime=$(date '+%Y-%m-%d_%H-%M-%S')
            target="$MK_TRANSCRIPTS_DIR/${mtime}.txt"
        else
            target="$MK_TRANSCRIPTS_DIR/$basename"
        fi
        [[ -e "$target" ]] && continue
        if mv "$f" "$target" 2>/dev/null; then
            moved=$((moved + 1))
        fi
    done

    if (( moved > 0 )); then
        print -P "${C[dim]}Migrated $moved transcript(s) to ${MK_TRANSCRIPTS_DIR/$HOME/~}${C[reset]}"
    fi
    rmdir "$old_dir" 2>/dev/null
}

# --- Setup wizard ---
cmd_setup() {
    print -P ""
    print -P "${C[bold]}meetink setup${C[reset]}"
    print -P ""

    # Hard requirement: Apple Silicon. Whisper.cpp + CoreML companion + MLX
    # all require ARM64 Mac. We bail clearly rather than silently producing
    # a broken install on Intel.
    local arch=$(uname -m)
    if [[ "$arch" != "arm64" ]]; then
        print -P "${C[red]}error:${C[reset]} meetink requires Apple Silicon (M-series). Detected: ${C[bold]}${arch}${C[reset]}"
        print -P "  Intel Macs aren't supported — the LLM stack (MLX) is ARM-only,"
        print -P "  and the Whisper acceleration we ship leans on the Apple Neural Engine."
        exit 1
    fi

    # Total download budget — surfaced up-front so users can bail before we
    # start pulling 3 GB of models. Numbers are rough but honest:
    #   whisper small.en .bin (~466 MB) + CoreML companion (~155 MB)  ≈ 620 MB
    #   sherpa-onnx WeSpeaker speaker-embedding ONNX                   ≈  25 MB
    #   mlx-community/Qwen3.5-2B-4bit (default) snapshot               ≈ 1.2 GB
    #   pip wheels (mlx-lm, sherpa-onnx, prompt_toolkit, …)            ≈ 200 MB
    #   brew tarballs (whisper-cpp, ffmpeg, uv if missing)              ≈ 100 MB
    print -P "${C[dim]}This will install on this Mac:${C[reset]}"
    print -P "  ${C[dim]}• whisper.cpp + CoreML encoder companion${C[reset]} ${C[bright_yellow]}~620 MB${C[reset]}"
    print -P "  ${C[dim]}• Speaker identification (sherpa-onnx)${C[reset]}    ${C[bright_yellow]}~25 MB${C[reset]}"
    print -P "  ${C[dim]}• Local LLM (Qwen3.5-2B via MLX)${C[reset]}          ${C[bright_yellow]}~1.2 GB${C[reset]}"
    print -P "  ${C[dim]}• Python venv + pip dependencies${C[reset]}          ${C[bright_yellow]}~200 MB${C[reset]}"
    print -P "  ${C[dim]}• Homebrew packages (whisper-cpp, ffmpeg)${C[reset]} ${C[bright_yellow]}~100 MB${C[reset]}"
    print -P "  ${C[dim]}                                              ────────${C[reset]}"
    print -P "  ${C[dim]}                                          ${C[bright_yellow]}~2.2 GB total${C[reset]}"
    print -P ""
    print -nP "  Continue? ${C[dim]}(Y/n)${C[reset]}: "
    local go=""
    read go
    if [[ "$go" == "n" || "$go" == "N" ]]; then
        print -P "${C[dim]}aborted.${C[reset]}"
        return 1
    fi

    mkdir -p "$MK_HOME"/{bin,models,prompts}
    mkdir -p "$MK_TRANSCRIPTS_DIR"
    migrate_transcripts

    # Copy default prompt if missing
    if [[ ! -f "$MK_PROMPT" ]] && [[ -f "$MK_ROOT/src/capture/prompts/default.txt" ]]; then
        cp "$MK_ROOT/src/capture/prompts/default.txt" "$MK_PROMPT"
        print -P "${C[green]}✓${C[reset]} Default prompt installed: ${C[dim]}$MK_PROMPT${C[reset]}"
    fi

    # 1. whisper.cpp via Homebrew
    print -P ""
    print -P "${C[bright_yellow]}[1/5] whisper.cpp${C[reset]}"
    install_whisper

    # 2. Swift capture binary + meetink-agent app bundle
    print -P ""
    print -P "${C[bright_yellow]}[2/5] capture binary${C[reset]}"
    if ! find_capture_binary >/dev/null 2>&1; then
        build_capture
    else
        print -P "${C[green]}✓${C[reset]} Capture binary present"
    fi
    # Always rebuild the agent — the Swift source evolves more than the
    # capture binary, and the build is cheap (~3 s) compared to the cost
    # of a stale agent dispatching a notification with the wrong fields.
    build_agent

    # 3. Whisper model picker (still interactive — the user genuinely cares
    # which language/quality tier to install, and small.en isn't always the
    # right default for non-English use).
    print -P ""
    print -P "${C[bright_yellow]}[3/5] whisper model${C[reset]}"
    model_setup_picker

    # 4. REPL Python venv + mlx-lm + Qwen3.5 default. Always installed —
    # this is "the only option" path the user asked for.
    print -P ""
    print -P "${C[bright_yellow]}[4/5] AI titling + /ask${C[reset]}"
    print -P "${C[dim]}Local LLM via Apple's MLX framework — Metal + Neural Engine acceleration.${C[reset]}"
    if ! repl_install_pytools; then
        print -P "${C[red]}error:${C[reset]} couldn't set up the REPL Python venv — aborting"
        exit 1
    fi
    llm_install

    # 5. Diarize sidecar + speaker-embedding ONNX. Also always installed.
    # /diarize on/off still controls whether it's *active* per-meeting; the
    # install just makes the option available without further setup.
    print -P ""
    print -P "${C[bright_yellow]}[5/5] speaker identification${C[reset]}"
    print -P "${C[dim]}sherpa-onnx (CoreML provider) for voice fingerprinting.${C[reset]}"
    diarize_install

    print -P ""
    print -P "${C[green]}${C[bold]}Setup complete.${C[reset]}"
    print -P ""
    print -P "  Next steps:"
    print -P "  ${C[dim]}1.${C[reset]} Grant ${C[bold]}Screen & System Audio Recording${C[reset]} permission to your terminal"
    print -P "     ${C[dim]}System Settings → Privacy & Security → Screen & System Audio Recording${C[reset]}"
    print -P "  ${C[dim]}2.${C[reset]} Grant ${C[bold]}Microphone${C[reset]} permission to your terminal"
    print -P "  ${C[dim]}3.${C[reset]} Run ${C[bright_cyan]}meetink start${C[reset]}"
    print -P ""
}

# --- Start whisper-server in background ---
start_whisper_server() {
    if [[ -f "$SERVER_PID_FILE" ]] && kill -0 "$(cat "$SERVER_PID_FILE")" 2>/dev/null; then
        print -P "${C[dim]}whisper-server already running${C[reset]}"
        return 0
    fi
    if ! command -v whisper-server >/dev/null 2>&1; then
        print -P "${C[red]}error:${C[reset]} whisper-server not found. Run ${C[bright_cyan]}meetink setup${C[reset]}"
        exit 1
    fi
    if [[ ! -f "$MK_MODEL" ]]; then
        print -P "${C[red]}error:${C[reset]} model not found at $MK_MODEL"
        print -P "  Run ${C[bright_cyan]}meetink setup${C[reset]} to download it"
        exit 1
    fi

    # Tinydiarize models embed `-tdrz` in the filename. When in use, ask
    # whisper-server to emit [SPEAKER_TURN] markers so main.swift can split
    # THEM into THEM-A / THEM-B / … as speakers change.
    local extra_args=()
    if [[ "$MK_MODEL" == *-tdrz* ]]; then
        extra_args+=(-tdrz)
        print -P "${C[dim]}  (tdrz model — speaker-turn detection enabled)${C[reset]}"
    fi

    print -P "${C[dim]}Starting whisper-server (port $MK_PORT)...${C[reset]}"
    whisper-server \
        -m "$MK_MODEL" \
        --port "$MK_PORT" \
        --host 127.0.0.1 \
        -t 4 \
        -l en \
        $extra_args \
        > /tmp/meetink-whisper.log 2>&1 &
    echo $! > "$SERVER_PID_FILE"
    disown 2>/dev/null || true

    for i in {1..30}; do
        if curl -s -o /dev/null "http://127.0.0.1:$MK_PORT/" 2>/dev/null; then
            print -P "${C[green]}✓${C[reset]} whisper-server ready"
            return 0
        fi
        sleep 1
    done
    print -P "${C[red]}error:${C[reset]} whisper-server failed to start. Check /tmp/meetink-whisper.log"
    exit 1
}

# --- Stop whisper-server ---
stop_whisper_server() {
    if [[ -f "$SERVER_PID_FILE" ]]; then
        local sp=$(cat "$SERVER_PID_FILE")
        if kill -0 "$sp" 2>/dev/null; then
            kill "$sp"
        fi
        rm -f "$SERVER_PID_FILE"
    fi
}

# --- Start command ---
cmd_start() {
    # Resolve the whitelist for *this* recording. Three sources, in
    # priority order:
    #   1. Trailing positional args (e.g. `/start alex stacey florin`)
    #      with an optional "with"/"whitelist" prefix for readability.
    #   2. MEETINK_WHITELIST env var (CSV). /watch sets this from the
    #      calendar event's attendees so the watcher's flow goes
    #      through the same code path as manual.
    #   3. Neither set → empty list, which signals "clear" below.
    #
    # No source = clear. This was the foot-gun: a stale whitelist from
    # the previous meeting was silently inherited, mis-restricting the
    # next /start. Now /start always reaches a definite state.
    local -a whitelist
    if (( $# > 0 )); then
        if [[ "$1" == "with" || "$1" == "whitelist" ]]; then
            shift
        fi
        whitelist=("$@")
    elif [[ -n "$MEETINK_WHITELIST" ]]; then
        whitelist=(${(s:,:)MEETINK_WHITELIST})
    fi

    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        print -P "${C[yellow]}Already recording${C[reset]} (PID $(cat "$PID_FILE"))"
        print -P "  Transcript: ${C[dim]}$MK_TRANSCRIPT${C[reset]}"
        exit 1
    fi

    local binary
    if ! binary=$(find_capture_binary); then
        print -P "${C[yellow]}Capture binary not found. Building...${C[reset]}"
        build_capture
        binary=$(find_capture_binary) || { print -P "${C[red]}error:${C[reset]} build did not produce a binary"; exit 1 }
    fi

    mkdir -p "$MK_TRANSCRIPTS_DIR" "$MK_HOME/prompts"
    migrate_transcripts

    # Re-resolve MK_MODEL each /start so /model use picks up next time.
    if [[ -z "$MEETINK_MODEL" ]]; then
        MK_MODEL=$(model_path "$(model_active)")
    fi

    # Each session writes to its own timestamped file so meetings don't
    # overwrite each other. live.txt is a symlink to the current session,
    # which keeps `/tail` and any external "tail -f live.txt" working.
    # Pre-create (touch) so window_open_tail's `tail -f` doesn't race the
    # Swift binary's first write — its header.write() will overwrite anyway.
    local session_file="$MK_TRANSCRIPTS_DIR/$(date '+%Y-%m-%d_%H-%M-%S').txt"
    touch "$session_file"
    ln -sfn "$session_file" "$MK_TRANSCRIPT"

    start_whisper_server
    # diarize-server is optional; quietly skipped if not installed.
    diarize_start
    # Clear cluster state from any previous recording so THEM-A in this
    # session is truly a new voice, not yesterday's leftover. Best-effort —
    # silently skipped if the server isn't up.
    curl -s -o /dev/null -X POST "http://127.0.0.1:$MK_DIARIZE_PORT/session/clear" 2>/dev/null || true

    # Apply per-session profile whitelist. With names → restrict
    # /identify to that set; without → clear any stale whitelist from
    # a previous recording. Always reaches a definite state so the
    # next /identify call hits exactly what the user expects.
    if (( ${#whitelist[@]} > 0 )); then
        local joined="${(j:,:)whitelist}"
        local resp=$(curl -s -X POST "http://127.0.0.1:$MK_DIARIZE_PORT/session/whitelist?profiles=$joined" 2>/dev/null)
        local applied=$(print -- "$resp" | sed -nE 's/.*"whitelist":[[:space:]]*\[([^]]*)\].*/\1/p' | sed 's/"//g; s/, */, /g')
        local unknown=$(print -- "$resp" | sed -nE 's/.*"unknown":[[:space:]]*\[([^]]*)\].*/\1/p' | sed 's/"//g; s/, */, /g')
        [[ -n "$applied" ]] && print -P "  ${C[dim]}Whitelist:${C[reset]} ${C[bright_cyan]}${applied}${C[reset]}"
        [[ -n "$unknown" ]] && print -P "  ${C[yellow]}⚠${C[reset]}  ${C[dim]}unknown (ignored):${C[reset]} ${unknown} ${C[dim]}— enrol via /profile add${C[reset]}"
    else
        curl -s -X POST "http://127.0.0.1:$MK_DIARIZE_PORT/session/whitelist?clear=true" >/dev/null 2>&1 || true
    fi

    MEETINK_MODEL="$MK_MODEL" \
    MEETINK_TRANSCRIPT="$session_file" \
    MEETINK_PROMPT="$MK_PROMPT" \
    MEETINK_ME_NAME="$(me_name_get)" \
        "$binary" 2>/tmp/meetink-capture.log &
    echo $! > "$PID_FILE"
    disown 2>/dev/null || true

    print -P ""
    print -P "${C[green]}${C[bold]}● Recording started${C[reset]}  (PID $(cat "$PID_FILE"))"
    print -P "  Transcript: ${C[bright_cyan]}${session_file/$HOME/~}${C[reset]}"
    print -P "  Live link:  ${C[dim]}${MK_TRANSCRIPT/$HOME/~}${C[reset]}"
    print -P "  Stop with: ${C[bright_cyan]}/stop${C[reset]}"

    # Surface the RAG indexer install hint when the deps aren't there
    # yet — /start is the moment users notice they're committing to a
    # recording, so it's the natural place to nudge them. Skipped when
    # the indexer is already available (no nag) or when index.sh wasn't
    # sourced for some reason (defensive).
    if typeset -f index_available >/dev/null 2>&1 && \
       ! index_available; then
        print -P "  ${C[dim]}Tip: run${C[reset]} ${C[bright_cyan]}/index install${C[reset]} ${C[dim]}(~50 MB) to enable RAG-backed${C[reset]} ${C[bright_cyan]}/ask${C[reset]} ${C[dim]}on long meetings.${C[reset]}"
    fi
    print -P ""

    # Auto-open a separate Terminal window tailing the live transcript so
    # the user can keep the meetink REPL in front for /stop while the
    # transcript scrolls in its own window. Skipped when MEETINK_NO_TAIL
    # is set (e.g. /watch-driven auto-records — the user is in the
    # meeting, not at the desk, so a popping tail window is intrusive).
    if [[ -z "$MEETINK_NO_TAIL" ]]; then
        window_open_tail "$MK_TRANSCRIPT"
    fi
}

# --- Stop command ---
cmd_stop() {
    if [[ ! -f "$PID_FILE" ]]; then
        print -P "${C[dim]}Not recording.${C[reset]}"
        exit 0
    fi
    local pid=$(cat "$PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
        print -P "${C[dim]}Stopping recording...${C[reset]}"
        kill -INT "$pid"
        for i in {1..30}; do
            kill -0 "$pid" 2>/dev/null || break
            sleep 1
        done
        if kill -0 "$pid" 2>/dev/null; then
            kill -9 "$pid"
        fi
    fi
    rm -f "$PID_FILE"
    stop_whisper_server
    # Note: we deliberately leave diarize-server running across /stop. It's
    # cheap (~25MB embedding model) and the user often wants to inspect or
    # promote clusters via /profile assign / /profile clusters after the
    # recording ends. Killing it would 503 those follow-ups. Use
    # /diarize stop or /diarize off to actually shut it down.
    # Close the tail window we opened on /start.
    window_close_tail

    print -P "${C[green]}✓${C[reset]} Stopped."

    # Run AI titling on the just-finished session (no-op if llama.cpp + the
    # tiny LLM aren't installed). title_session_file may rename the file and
    # update the live.txt symlink target.
    if [[ -L "$MK_TRANSCRIPT" ]]; then
        local actual=$(readlink "$MK_TRANSCRIPT" 2>/dev/null)
        [[ -n "$actual" && -f "$actual" ]] && title_session_file "$actual"
    fi

    if [[ -f "$MK_TRANSCRIPT" ]]; then
        local lines=$(wc -l < "$MK_TRANSCRIPT" | tr -d ' ')
        local final=$(readlink "$MK_TRANSCRIPT" 2>/dev/null)
        [[ -z "$final" ]] && final="$MK_TRANSCRIPT"
        print -P "  Transcript: ${C[bright_cyan]}${final/$HOME/~}${C[reset]} ${C[dim]}($lines lines)${C[reset]}"
    fi
}

# --- Status command ---
cmd_status() {
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        local pid=$(cat "$PID_FILE")
        local lines=0
        [[ -f "$MK_TRANSCRIPT" ]] && lines=$(wc -l < "$MK_TRANSCRIPT" | tr -d ' ')
        print -P "${C[green]}● recording${C[reset]} (PID $pid)"
        print -P "  Transcript: ${C[dim]}$MK_TRANSCRIPT${C[reset]} ${C[dim]}($lines lines)${C[reset]}"
    else
        rm -f "$PID_FILE" 2>/dev/null
        print -P "${C[dim]}○ not recording${C[reset]}"
        if [[ -f "$MK_TRANSCRIPT" ]]; then
            print -P "  Last transcript: ${C[dim]}$MK_TRANSCRIPT${C[reset]}"
        fi
    fi
    print -P ""
    print -P "  ${C[bold]}Model:${C[reset]}     ${C[cyan]}$(model_active)${C[reset]}"
    print -P "  ${C[bold]}Folder:${C[reset]}    ${C[dim]}${MK_TRANSCRIPTS_DIR/$HOME/~}${C[reset]}"

    # Speaker-ID
    print -nP "  ${C[bold]}Speakers:${C[reset]}  "
    if ! diarize_available; then
        print -P "${C[dim]}not installed${C[reset]} ${C[dim]}(/diarize install)${C[reset]}"
    elif [[ "$(diarize_enabled_get)" == "false" ]]; then
        print -P "${C[dim]}off${C[reset]} ${C[dim]}(/diarize on)${C[reset]}"
    elif diarize_running; then
        local n=0
        if [[ -d "$MK_HOME/profiles" ]]; then
            # null_glob locally so missing .npz files don't error.
            setopt local_options null_glob
            local files=("$MK_HOME/profiles"/*.npz)
            n=${#files[@]}
        fi
        local plural=""
        (( n != 1 )) && plural="s"
        print -P "${C[green]}● running${C[reset]} ${C[dim]}($n profile$plural enrolled)${C[reset]}"
    elif [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        # Recording active but server hasn't bound yet — transient.
        print -P "${C[yellow]}starting${C[reset]}"
    else
        print -P "${C[cyan]}ready${C[reset]} ${C[dim]}(starts on /start)${C[reset]}"
    fi

    # AI titling
    print -nP "  ${C[bold]}Titling:${C[reset]}   "
    if llm_available; then
        print -P "${C[green]}● ready${C[reset]} ${C[dim]}(Qwen3-0.6B)${C[reset]}"
    else
        print -P "${C[dim]}off${C[reset]} ${C[dim]}(/llm install)${C[reset]}"
    fi
}

# --- Tail command ---
# Open (or raise) a separate Terminal.app window tailing the live transcript.
# The meetink REPL stays in the foreground so /stop is still reachable —
# tailing inline would block the REPL until Ctrl+C.
cmd_tail() {
    if [[ ! -f "$MK_TRANSCRIPT" ]]; then
        print -P "${C[red]}error:${C[reset]} no transcript at $MK_TRANSCRIPT"
        print -P "  ${C[dim]}Run${C[reset]} ${C[bright_cyan]}/start${C[reset]} ${C[dim]}first.${C[reset]}"
        exit 1
    fi
    window_open_tail "$MK_TRANSCRIPT"
}

# --- Help ---
cmd_help() {
    print -P ""
    print -P "${C[bold]}meetink${C[reset]} ${C[dim]}v${MEETINK_VERSION}${C[reset]} — local-first meeting transcription"
    print -P ""
    print -P "${C[bright_yellow]}USAGE${C[reset]}"
    print -P "  meetink [command]"
    print -P ""
    print -P "${C[bright_yellow]}COMMANDS${C[reset]}"
    bullet "setup    " "install dependencies + download model"
    bullet "start    " "begin transcribing system audio + microphone"
    bullet "stop     " "stop recording, save transcript"
    bullet "status   " "show whether recording is active"
    bullet "tail     " "follow the live transcript"
    bullet "help     " "show this help"
    print -P ""
    print -P "${C[bright_yellow]}OUTPUT${C[reset]}"
    print -P "  Transcripts:  ${C[dim]}${MK_TRANSCRIPTS_DIR/$HOME/~}/${C[reset]} ${C[dim]}(timestamped per session, live.txt symlinks to current)${C[reset]}"
    print -P "  Prompts:      ${C[dim]}$MK_HOME/prompts/default.txt${C[reset]} ${C[dim]}(edit to customize whisper context)${C[reset]}"
    print -P "  Models:       ${C[dim]}$MK_HOME/models/${C[reset]}"
    print -P ""
    print -P "${C[bright_yellow]}ENV OVERRIDES${C[reset]}"
    print -P "  ${C[dim]}MEETINK_HOME${C[reset]}             custom data (internal) directory"
    print -P "  ${C[dim]}MEETINK_TRANSCRIPTS_DIR${C[reset]}  custom directory for transcripts"
    print -P "  ${C[dim]}MEETINK_MODEL${C[reset]}            custom whisper model path"
    print -P "  ${C[dim]}MEETINK_TRANSCRIPT${C[reset]}       custom live-symlink path"
    print -P "  ${C[dim]}MEETINK_PROMPT${C[reset]}           custom prompt path"
    print -P ""
    print -P "${C[dim]}https://github.com/sservaes/meetink${C[reset]}"
    print -P ""
}

# --- Dispatch ---
# One-time legacy rename migration runs before any subcommand.
migrate_legacy_install

case "${1:-}" in
    "")
        # Bare invocation: launch the Python REPL on a TTY, fall back to the
        # welcome screen (so piped/script callers still get something useful).
        if [[ -t 0 && -t 1 ]]; then
            launch_python_repl
        else
            welcome_screen
        fi
        ;;
    welcome)           welcome_screen ;;
    setup)             cmd_setup ;;
    start)             shift; cmd_start "$@" ;;
    stop)              cmd_stop ;;
    status)            cmd_status ;;
    tail|follow)       cmd_tail ;;
    help|--help|-h)    cmd_help ;;
    # Slash commands invoked from the Python REPL map to their bare-name
    # subcommands here. Most are already wired above (start/stop/status/etc);
    # the rest dispatch to the existing cmd_* / cmd_X helpers.
    model)             shift; cmd_model "$@" ;;
    llm)               shift; cmd_llm "$@" ;;
    diarize)           shift; cmd_diarize "$@" ;;
    profile|profiles)  shift; cmd_profile "$@" ;;
    project|projects)  shift; cmd_project "$@" ;;
    me)                shift; cmd_me "$@" ;;
    ask)               shift; cmd_ask "$@" ;;
    context)           shift; cmd_context "$@" ;;
    index)             shift; cmd_index "$@" ;;
    watch)             shift; cmd_watch "$@" ;;
    _build_agent)      build_agent ;;
    _build_capture)    build_capture ;;
    prompt|vocab)
        mkdir -p "${MK_PROMPT:h}"
        [[ -f "$MK_PROMPT" ]] || touch "$MK_PROMPT"
        open -t "$MK_PROMPT"
        print -P "  ${C[dim]}Opened${C[reset]} ${C[bright_cyan]}$MK_PROMPT${C[reset]}"
        ;;
    transcripts|ls)
        if [[ ! -d "$MK_TRANSCRIPTS_DIR" ]] || [[ -z "$(ls -A "$MK_TRANSCRIPTS_DIR" 2>/dev/null)" ]]; then
            print -P "${C[dim]}No transcripts in ${MK_TRANSCRIPTS_DIR/$HOME/~}${C[reset]}"
        else
            print -P "${C[dim]}${MK_TRANSCRIPTS_DIR/$HOME/~}/${C[reset]}"
            ls -lhT "$MK_TRANSCRIPTS_DIR" 2>/dev/null || ls -lh "$MK_TRANSCRIPTS_DIR"
        fi
        ;;
    _migrate)          migrate_transcripts ;;
    version|--version|-v) print "meetink v$MEETINK_VERSION" ;;
    *)
        print -P "${C[red]}unknown command:${C[reset]} $1"
        print -P "Run ${C[bright_cyan]}meetink help${C[reset]} for available commands."
        exit 1
        ;;
esac
